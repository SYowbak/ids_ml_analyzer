{
    "version": "2.0",
    "description": "Unified Master Schema for IDS ML Analyzer",
    "features": [
        {"name": "duration", "type": "float", "default": 0.0, "description": "Flow duration in seconds"},
        {"name": "protocol", "type": "int", "default": 0, "description": "IANA Protocol number (6=TCP, 17=UDP, etc)"},
        {"name": "packets_fwd", "type": "int", "default": 0, "description": "Total packets in forward direction"},
        {"name": "packets_bwd", "type": "int", "default": 0, "description": "Total packets in backward direction"},
        {"name": "bytes_fwd", "type": "float", "default": 0.0, "description": "Total bytes in forward direction"},
        {"name": "bytes_bwd", "type": "float", "default": 0.0, "description": "Total bytes in backward direction"},
        {"name": "fwd_packet_length_max", "type": "float", "default": 0.0},
        {"name": "fwd_packet_length_min", "type": "float", "default": 0.0},
        {"name": "fwd_packet_length_mean", "type": "float", "default": 0.0},
        {"name": "fwd_packet_length_std", "type": "float", "default": 0.0},
        {"name": "bwd_packet_length_max", "type": "float", "default": 0.0},
        {"name": "bwd_packet_length_min", "type": "float", "default": 0.0},
        {"name": "bwd_packet_length_mean", "type": "float", "default": 0.0},
        {"name": "bwd_packet_length_std", "type": "float", "default": 0.0},
        {"name": "flow_bytes/s", "type": "float", "default": 0.0},
        {"name": "flow_packets/s", "type": "float", "default": 0.0},
        {"name": "iat_mean", "type": "float", "default": 0.0},
        {"name": "iat_std", "type": "float", "default": 0.0},
        {"name": "flow_iat_max", "type": "float", "default": 0.0},
        {"name": "flow_iat_min", "type": "float", "default": 0.0},
        {"name": "fwd_iat_mean", "type": "float", "default": 0.0},
        {"name": "fwd_iat_std", "type": "float", "default": 0.0},
        {"name": "fwd_iat_max", "type": "float", "default": 0.0},
        {"name": "fwd_iat_min", "type": "float", "default": 0.0},
        {"name": "bwd_iat_mean", "type": "float", "default": 0.0},
        {"name": "bwd_iat_std", "type": "float", "default": 0.0},
        {"name": "bwd_iat_max", "type": "float", "default": 0.0},
        {"name": "bwd_iat_min", "type": "float", "default": 0.0},
        {"name": "tcp_syn_count", "type": "int", "default": 0},
        {"name": "tcp_ack_count", "type": "int", "default": 0},
        {"name": "tcp_fin_count", "type": "int", "default": 0},
        {"name": "tcp_rst_count", "type": "int", "default": 0},
        {"name": "psh_flag_count", "type": "int", "default": 0},
        {"name": "urg_flag_count", "type": "int", "default": 0},
        {"name": "cwr_flag_count", "type": "int", "default": 0},
        {"name": "ece_flag_count", "type": "int", "default": 0},
        {"name": "fwd_bwd_ratio", "type": "float", "default": 0.0},
        {"name": "avg_packet_size", "type": "float", "default": 0.0},
        {"name": "avg_fwd_segment_size", "type": "float", "default": 0.0},
        {"name": "avg_bwd_segment_size", "type": "float", "default": 0.0},
        {"name": "dst_port", "type": "int", "default": 0},
        {"name": "packet_rate", "type": "float", "default": 0.0, "derived": true, "formula": "(packets_fwd + packets_bwd) / max(duration, 1e-6)"},
        {"name": "byte_rate", "type": "float", "default": 0.0, "derived": true, "formula": "(bytes_fwd + bytes_bwd) / max(duration, 1e-6)"}
    ],
    "target_label": "label"
}